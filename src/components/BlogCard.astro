---
import AvatarComponent from '@/components/ui/avatar'
import { Badge } from '@/components/ui/badge'
import { Separator } from '@/components/ui/separator'
import {
  getCombinedReadingTime,
  getSubpostCount,
  isSubpost,
  parseAuthors,
} from '@/lib/data-utils'
import { cn, formatDate } from '@/lib/utils'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import type { CollectionEntry } from 'astro:content'
import { cva, type VariantProps } from 'class-variance-authority'
import { FEATURE_TOGGLE } from '../consts'
import Link from './Link.astro'

const blogCardVariants = cva(
  'hover:bg-secondary/50 rounded-xl border p-4 transition-colors duration-300 ease-in-out',
  {
    variants: {
      variant: {
        default: '',
        hero: '',
      },
    },
    defaultVariants: {
      variant: 'default',
    },
  },
)

const blogCardLinkVariants = cva('flex flex-col gap-4', {
  variants: {
    variant: {
      default: 'sm:flex-row',
      hero: '',
    },
  },
  defaultVariants: {
    variant: 'default',
  },
})

const blogCardImageWrapperVariants = cva('', {
  variants: {
    variant: {
      default: 'max-w-3xs sm:shrink-0',
      hero: 'w-full',
    },
  },
  defaultVariants: {
    variant: 'default',
  },
})

const blogCardImageVariants = cva('rounded-lg object-cover', {
  variants: {
    variant: {
      default: '',
      hero: 'h-80 w-full',
    },
  },
  defaultVariants: {
    variant: 'default',
  },
})

const blogCardTitleVariants = cva('mb-1', {
  variants: {
    variant: {
      default: 'text-lg font-medium',
      hero: 'text-2xl font-semibold',
    },
  },
  defaultVariants: {
    variant: 'default',
  },
})

const blogCardDescriptionVariants = cva('text-muted-foreground', {
  variants: {
    variant: {
      default: 'mb-2 text-sm',
      hero: 'mb-4 text-base',
    },
  },
  defaultVariants: {
    variant: 'default',
  },
})

interface Props extends VariantProps<typeof blogCardVariants> {
  entry: CollectionEntry<'posts'>
  class?: string
}

const { entry, variant = 'default', class: className } = Astro.props
const formattedDate = formatDate(entry.data.date)
const readTime = await getCombinedReadingTime(entry.id)
const authors = await parseAuthors(entry.data.authors ?? [])
const subpostCount = !isSubpost(entry.id) ? await getSubpostCount(entry.id) : 0
---

<div class={cn(blogCardVariants({ variant }), className)}>
  <Link
    href={`/${entry.collection}/${entry.id}`}
    class={blogCardLinkVariants({ variant })}
  >
    {
      entry.data.image && (
        <div class={blogCardImageWrapperVariants({ variant })}>
          <Image
            src={entry.data.image}
            alt={entry.data.title}
            width={1200}
            height={630}
            class={blogCardImageVariants({ variant })}
          />
        </div>
      )
    }

    <div class="grow">
      <h3 class={blogCardTitleVariants({ variant })}>
        {entry.data.title}
      </h3>
      <p class={blogCardDescriptionVariants({ variant })}>
        {entry.data.description}
      </p>

      <div
        class="text-muted-foreground mb-2 flex flex-wrap items-center gap-x-2 text-xs"
      >
        {
          FEATURE_TOGGLE.authors && authors.length > 0 && (
            <>
              {authors.map((author) => (
                <div class="flex items-center gap-x-1.5">
                  <AvatarComponent
                    client:load
                    src={author.avatar}
                    alt={author.name}
                    fallback={author.name[0]}
                    className="size-5 rounded-full"
                  />
                  <span>{author.name}</span>
                </div>
              ))}
              <Separator orientation="vertical" className="h-4!" />
            </>
          )
        }
        <span>{formattedDate}</span>
        <Separator orientation="vertical" className="h-4!" />
        <span>{readTime}</span>
        {
          subpostCount > 0 && (
            <>
              <Separator orientation="vertical" className="h-4!" />
              <span class="flex items-center gap-1">
                <Icon name="lucide:file-text" class="size-3" />
                {subpostCount} subpost{subpostCount === 1 ? '' : 's'}
              </span>
            </>
          )
        }
      </div>

      {
        entry.data.tags && (
          <div class="flex flex-wrap gap-2">
            {entry.data.tags.map((tag) => (
              <Badge variant="secondary" className="flex items-center gap-x-1">
                <Icon name="lucide:hash" class="size-3" />
                {tag}
              </Badge>
            ))}
          </div>
        )
      }
    </div>
  </Link>
</div>
